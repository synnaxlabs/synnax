---
import { Flex, Text } from "@synnaxlabs/pluto";

interface Props {
    brandColor: string;
    quote: string;
    name: string;
    title?: string;
    variant?: "hero" | "standard";
}

const { brandColor, quote, name, title, variant = "standard" } = Astro.props;
---

<div class={`testimonial-card testimonial-card--${variant}`} style={`--brand-color: ${brandColor};`}>
    <div class="testimonial-bg-decoration"><slot name="bg" /></div>
    <Flex.Box className="testimonial-card-content" justify="start" align="start">
        <Text.Text level="h4" className="testimonial-quote">
            "{quote}"
        </Text.Text>
        <Flex.Box className="testimonial-bottom" direction="x" justify="between" align="end">
            <Flex.Box className="testimonial-author">
                <Text.Text level="h5" className="testimonial-name">{name}</Text.Text>
                {title && <Text.Text level="h5" className="testimonial-title">{title}</Text.Text>}
            </Flex.Box>
            <div class="testimonial-logo"><slot name="logo" /></div>
        </Flex.Box>
    </Flex.Box>
</div>

<style is:global>
    .testimonial-card {
        position: relative;
        overflow: hidden;
        background:
            radial-gradient(
                ellipse at 15% 15%,
                color-mix(in srgb, var(--brand-color), #fff 5%) 0%,
                transparent 40%
            ),
            linear-gradient(
                135deg,
                var(--brand-color) 0%,
                color-mix(in srgb, var(--brand-color), #000 20%) 100%
            );
        border-radius: 2rem;
        padding: 5rem;
        border: none;
        box-shadow:
            inset 0 1px 0 0 rgba(255, 255, 255, 0.04),
            0 4px 24px -4px rgba(0, 0, 0, 0.3);
    }

    /* Noise texture overlay */
    .testimonial-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        opacity: 0.035;
        mix-blend-mode: overlay;
        pointer-events: none;
        z-index: 1;
    }

    .testimonial-card::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 2rem;
        padding: 1px;
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--brand-color), #fff 40%) 0%,
            transparent 50%,
            color-mix(in srgb, var(--brand-color), #000 30%) 100%
        );
        -webkit-mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        pointer-events: none;
        z-index: 3;
    }

    .testimonial-bg-decoration {
        position: absolute;
        right: -25%;
        top: 50%;
        transform: translateY(-50%);
        height: 110%;
        opacity: 0.05;
        pointer-events: none;
        z-index: 1;
        color: #fff;
    }

    .testimonial-bg-decoration svg {
        height: 100%;
        width: auto;
    }

    .testimonial-card-content {
        position: relative;
        z-index: 2;
        height: 100%;
        gap: 3rem;
    }

    .testimonial-bottom {
        margin-top: auto;
        width: 100%;
    }

    .testimonial-logo {
        display: flex;
        align-items: flex-end;
    }

    .testimonial-quote {
        color: #fff;
        max-width: 75%;
    }

    .testimonial-author {
        gap: 0.3rem;
        border-left: 1px solid rgba(255, 255, 255, 0.2);
        padding-left: 1.2rem;
    }

    .testimonial-name {
        color: #fff;
    }

    .testimonial-title {
        color: #fff;
    }

    /* Hero variant — larger card */
    .testimonial-card--hero {
        padding: 5rem;
    }


</style>
