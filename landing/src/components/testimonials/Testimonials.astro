            </svg>
        </TestimonialCard>
        <TestimonialCard
            brandColor="rgb(140, 20, 20)"
            quote="The potential of this product and the implications it has for Honeywell's future are huge."
            name="Juan Fuentes"
            title="Head of Digital Transformation"
        >
            <div slot="logo" style="color: #fff; height: 9.5rem; display: flex; margin-bottom: -1.5rem;"><Honeywell /></div>
        </TestimonialCard>
        <TestimonialCard
            brandColor="rgb(221, 126, 54)"
            quote="We used to juggle four or five different LabVIEW applications. Synnax does it all in one place."
            name="Jonathan Grimm"
            title="Staff Test Engineer"
        >
            <div slot="logo" style="color: #fff; height: 8rem; display: flex;"><Firehawk /></div>
        </TestimonialCard>
    </div>
</Flex.Box>

<style is:global>
    .testimonials {
        padding: 6rem 0 25rem;
        gap: 20rem;
    }

    .testimonials-label {
        color: var(--pluto-gray-l7);
        font-weight: 500;
    }

    .testimonials-grid {
        display: grid;
        grid-template-columns: 5fr 4fr;
        grid-template-rows: 1fr 1fr;
        gap: 4rem;
        width: 100%;
        height: 700px;
        position: relative;
    }

    .testimonials-grid::before {
        content: "";
        position: absolute;
        inset: -16px;
        border-radius: 2.5rem;
        border: 1px solid rgba(255, 255, 255, 0.15);
        pointer-events: none;
        mask-image: linear-gradient(135deg, rgba(0,0,0,1) 0%, transparent 50%);
        -webkit-mask-image: linear-gradient(135deg, rgba(0,0,0,1) 0%, transparent 50%);
    }

    .testimonials-grid .testimonial-card:nth-child(1) {
        grid-row: 1 / -1;
    }

    @media (max-width: 800px) {
        .testimonials-grid {
            grid-template-columns: 1fr;
            grid-auto-rows: auto;
            height: auto;
        }

        .testimonials-grid .testimonial-card:nth-child(1) {
            grid-row: span 1;
        }
    }
</style>
