---
import { Flex, Text } from "@synnaxlabs/pluto";
import TestimonialCard from "./TestimonialCard.astro";
import XBow from "@/components/logos/XBow.astro";
import Honeywell from "@/components/logos/Honeywell.astro";
import Firehawk from "@/components/logos/Firehawk.astro";
---

<Flex.Box el="section" className="testimonials">
    <Text.Text level="h4" variant="code" className="testimonials-label">01. Testimonials</Text.Text>
