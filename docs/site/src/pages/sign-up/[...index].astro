---
import { SignUpForm } from "@/components/auth/SignUpForm";
import Root from "@/layouts/Root.astro";
---

<Root frontmatter={{ title: "Sign Up", description: "Create a Synnax account" }}>
    <div class="auth-page">
        <SignUpForm client:load />
    </div>
</Root>

<style is:global>
    .auth-page {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        min-height: calc(100vh - 100px);
        padding: 4rem 2rem;
    }
</style>
