---
import { Logo } from "@synnaxlabs/media";
import { Icon, Button, Text, Flex } from "@synnaxlabs/pluto";
import { Show, UserButton } from "@clerk/astro/components";
import Search from "@/components/search/Search.astro";
import { PageMobile } from "@/components/nav/Page";
const url = Astro.url.pathname;
---

<Flex.Box className="main-header" justify="center" align="center" el="header" empty>
    <Flex.Box className="header-row" justify="center" align="center">
        <Flex.Box
            className="header-content"
            direction="x"
            justify="between"
            align="center"
        >
            <Flex.Box direction="x" align="center" gap={4}>
                <a href="https://synnaxlabs.com" class="logo-link">
                    <Logo variant="title" />
                </a>
                <Flex.Box direction="x" className="header-nav" align="center" gap={1}>
                    <Button.Button
                        variant="text"
                        className={`nav-link ${url.includes("reference") ? "nav-link--active" : ""}`}
                        href="/reference/"
                    >
                        Reference
                    </Button.Button>
                    <Button.Button
                        variant="text"
                        className={`nav-link ${url.includes("blog") ? "nav-link--active" : ""}`}
                        href="/blog/"
                    >
                        Blog
                    </Button.Button>
                    <Button.Button
                        variant="text"
                        className={`nav-link ${url.includes("releases") ? "nav-link--active" : ""}`}
                        href="/releases/"
                    >
                        Releases
                    </Button.Button>
                </Flex.Box>
            </Flex.Box>
            <Flex.Box direction="x" align="center" gap="small">
                <Search />
                <Button.Button
                    className="demo-button"
                    variant="filled"
                    href="https://synnaxlabs.com/#contact"
                >
                    Book a Demo
                </Button.Button>
                <Show when="signed-out">
                    <Button.Button
                        className="sign-in-button"
                        variant="text"
                        href="/sign-in"
                    >
                        Sign In
                    </Button.Button>
                </Show>
                <Show when="signed-in">
                    <UserButton />
                </Show>
                <Button.Button
                    className="version-button"
                    variant="outlined"
                    href="https://github.com/synnaxlabs/synnax"
                >
                    <p class="version" transition:persist></p>
                    <Icon.Logo.Github />
                </Button.Button>
                <PageMobile client:only="react" currentPage={Astro.url.pathname} />
            </Flex.Box>
        </Flex.Box>
    </Flex.Box>
</Flex.Box>

<style is:global>
    .main-header {
        z-index: 4;
        position: sticky;
        top: 0;
        background: var(--pluto-gray-l2-30);
        backdrop-filter: blur(3rem);
        -webkit-backdrop-filter: blur(3rem);

        .header-row {
            height: var(--nav-height);
            border-bottom: var(--pluto-border);
            border-color: var(--pluto-gray-l4);
            width: 100%;
        }

        .header-content {
            width: 100%;
            max-width: var(--max-width);
            padding: 0 7rem;
        }

        .logo-link {
            text-decoration: none;
            display: flex;
            align-items: center;

            & .synnax-logo--title {
                height: 4.5rem;
            }
        }

        .nav-link {
            font-size: var(--pluto-small-size);
            font-weight: 400;
            color: var(--pluto-gray-l8);
            text-decoration: none;

            &:hover {
                color: var(--pluto-gray-l10);
                text-decoration: none;
            }
        }

        .nav-link--active {
            color: var(--pluto-gray-l10);
        }

        .demo-button {
            text-decoration: none;
            font-size: 2rem;
            font-weight: 500;
        }

        .version-button {
            text-decoration: none;

            & p {
                color: var(--pluto-gray-l8);
                font-size: var(--pluto-small-size);
                font-weight: 400;
                text-decoration: none;
            }
            & .pluto-icon {
                color: var(--pluto-gray-l9);
                height: 2.5rem;
                width: 2.5rem;
            }
        }

        .sign-in-button {
            font-size: 2rem;
            font-weight: 500;
            text-decoration: none;
        }

        [data-clerk-id] {
            zoom: 2.667;
        }

        .cl-userButtonTrigger {
            zoom: 2.667;
        }

        .mobile-menu-btn {
            display: none;
        }
    }

    .mobile-menu-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.8rem;
        margin-right: -0.8rem;
    }

    .mobile-menu-icon,
    .mobile-menu-icon::before,
    .mobile-menu-icon::after {
        display: block;
        width: 2.2rem;
        height: 2px;
        background: var(--pluto-gray-l9);
        border-radius: 1px;
        transition: all 0.2s ease;
    }

    .mobile-menu-icon {
        position: relative;
    }

    .mobile-menu-icon::before,
    .mobile-menu-icon::after {
        content: "";
        position: absolute;
        left: 0;
    }

    .mobile-menu-icon::before {
        top: -0.7rem;
    }

    .mobile-menu-icon::after {
        top: 0.7rem;
    }

    .mobile-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 49;
        opacity: 0;
        transition: opacity 0.25s ease;
    }

    .mobile-overlay--open {
        display: block;
        opacity: 1;
    }

    .mobile-drawer {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100dvh;
        background: var(--pluto-gray-l1);
        z-index: 50;
        transform: translateX(100%);
        transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        display: none;
        flex-direction: column;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
    }

    .mobile-drawer--open {
        transform: translateX(0);
    }

    .mobile-drawer-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 2rem;
        height: var(--nav-height);
        border-bottom: var(--pluto-border);
        flex-shrink: 0;
    }

    .mobile-drawer-header .logo-link .synnax-logo--title {
        height: 3.5rem;
    }

    .mobile-close-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.8rem;
        margin-right: -0.8rem;
    }

    .mobile-close-icon {
        display: block;
        width: 2.2rem;
        height: 2.2rem;
        position: relative;
    }

    .mobile-close-icon::before,
    .mobile-close-icon::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 0;
        width: 100%;
        height: 2px;
        background: var(--pluto-gray-l9);
        border-radius: 1px;
    }

    .mobile-close-icon::before {
        transform: rotate(45deg);
    }

    .mobile-close-icon::after {
        transform: rotate(-45deg);
    }

    .mobile-drawer-links {
        display: flex;
        flex-direction: column;
        padding: 1.5rem 0;
    }

    .mobile-drawer-section-label {
        font-size: 1.4rem;
        font-weight: 600;
        color: var(--pluto-gray-l6);
        font-family: var(--pluto-font-family);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 1rem 2rem 0.5rem;
    }

    .mobile-drawer-link {
        display: block;
        padding: 1.2rem 2rem;
        font-size: 1.8rem;
        font-weight: 500;
        font-family: var(--pluto-font-family);
        color: var(--pluto-gray-l9);
        text-decoration: none;

        &:hover {
            background: var(--pluto-gray-l2);
            text-decoration: none;
        }
    }

    .mobile-drawer-divider {
        height: 1px;
        background: var(--pluto-gray-l3);
        margin: 0.8rem 2rem;
    }

    .mobile-drawer-tree {
        flex: 1;
        overflow-y: auto;
        padding-bottom: 2rem;
    }

    body.mobile-menu-open {
        overflow: hidden;
    }

    @media (max-width: 800px) {
        .main-header {
            .header-content {
                padding: 0 3rem;
            }
            .header-nav {
                display: none;
            }
            .demo-button {
                display: none;
            }
            .sign-in-button {
                display: none;
            }
            .cl-userButtonTrigger {
                display: none;
            }
            .version-button {
                display: none;
            }
            .mobile-menu-btn {
                display: block;
            }
            .mobile-drawer {
                display: flex;
            }
        }
    }

    @media (max-width: 800px) and (hover: none) {
        .main-header {
            z-index: 100;
            flex-direction: column-reverse !important;
            position: fixed;
            bottom: 0px;
            top: unset;
            width: 100%;
            border-top: var(--pluto-border);
        }
    }
</style>
