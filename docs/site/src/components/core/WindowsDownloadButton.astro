---
import { Button, Icon } from "@synnaxlabs/pluto";
import { fetchVersion } from "@/util/fetchVersion";
const { userId } = Astro.locals.auth();

const version = await fetchVersion();
const url = `https://github.com/synnaxlabs/synnax/releases/download/synnax-v${version}/synnax-setup-v${version}.exe`;
---

{userId ? (
    <Button.Button href={url} size="large" variant="filled">
        <Icon.Download />
        Download Synnax v{version} for Windows
    </Button.Button>
) : (
    <Button.Button href="/sign-in" size="large" variant="filled">
        <Icon.Download />
        Sign in to Download for Windows
    </Button.Button>
)}
