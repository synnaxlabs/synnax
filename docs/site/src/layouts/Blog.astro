---
import Article from "@/components/article/Article.astro";
import OnThisPage from "@/components/nav/OnThisPage.astro";
import Root from "@/layouts/Root.astro";

const { headings, frontmatter } = Astro.props;
const { title, heading, description, published } = frontmatter;
---

<Root frontmatter={frontmatter} headings={headings}>
    <section>
        <Article
            url={Astro.url.pathname}
            title={heading ?? title}
            description={description}
            showBreadcrumb={true}
            published={published}
        >
            <slot />
        </Article>
        <OnThisPage headings={headings} url={Astro.url} hideFeedback>
            <div class="blog-human-note">
                All of our blog posts were written and edited carefully by humans
            </div>
        </OnThisPage>
    </section>
</Root>

<style is:global>
    .blog-meta {
        position: absolute;
        top: 5rem;
        right: 8rem;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 1.15rem;
    }

    .blog-human-note {
        color: var(--pluto-gray-l7);
        font-family: var(--pluto-font-family);
        font-style: italic;
        font-size: var(--pluto-small-size);
        font-weight: 400;
        line-height: 160%;
        border-top: var(--pluto-border);
        padding-top: 2rem;
    }

    .blog-published {
        color: var(--pluto-gray-l8);
        font-family: var(--pluto-font-family);
        font-size: var(--pluto-small-size);
        font-weight: 400;
        background-color: var(--pluto-gray-l2);
        border: var(--pluto-border);
        border-radius: 1rem;
        padding: 0.5rem 1.5rem;
    }
</style>
